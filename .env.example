DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=inmarc_db
DB_USER=your_db_user
DB_PASS=your_strong_db_password

# Comma-separated origins, example:
# APP_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
APP_ALLOWED_ORIGINS=https://yourdomain.com

# Keep 0 in production. Set 1 only briefly for controlled maintenance.
ALLOW_MAINTENANCE_ENDPOINTS=0
